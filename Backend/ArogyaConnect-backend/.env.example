# ── Server ───────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/arogyaconnect

# ── JWT ───────────────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_strong_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m

JWT_REFRESH_SECRET=replace_with_different_strong_secret
JWT_REFRESH_EXPIRES=7d

# ── Frontend URL (for CORS + password-reset links) ────────────────
FRONTEND_URL=http://localhost:5173

# ── Admin seed (used by src/scripts/seedAdmin.js) ─────────────────
ADMIN_EMAIL=admin@arogyaconnect.in
ADMIN_PASSWORD=Admin@1234
ADMIN_NAME=Platform Admin

# ── Daily.co Video (Module 7) ────────────────────────────────────
DAILY_API_KEY=897a419c8a9051d3cc9a3d30a160eb8f25e4a369a2bc2ddf1e3370d1da3355d1

DAILY_DOMAIN=ArogyaConnect.daily.co

# ── Email / SMTP (optional — needed for forgot-password flow) ─────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="ArogyaConnect <noreply@arogyaconnect.in>"
